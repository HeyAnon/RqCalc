<UserControl x:Class="Anon.RQ_Calc.WPF.TalentDescriptionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Anon.RQ_Calc.WPF"
             mc:Ignorable="d" 
              Margin="0" Padding="0">

    <StackPanel Margin="0">

        <local:TextTemplateControl DataContext="{Binding Body}" Padding="0"  />

        <ItemsControl ItemsSource="{Binding Buffs}" Margin="0" Padding="0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:TextTemplateControl />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
    
</UserControl>
