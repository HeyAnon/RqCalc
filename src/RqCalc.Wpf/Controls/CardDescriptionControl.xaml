<UserControl x:Class="Anon.RQ_Calc.WPF.CardDescriptionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Anon.RQ_Calc.WPF"
             mc:Ignorable="d" 
             Margin="0" Padding="0">

    <StackPanel Margin="0">

        <local:BonusCollectionControl DataContext="{Binding Card}" VerticalAlignment="Center" Foreground="{Binding BonusForeground, RelativeSource={RelativeSource AncestorType={x:Type local:CardDescriptionControl}}}" />
        
        <ItemsControl ItemsSource="{Binding BuffDescriptions}" Margin="0" Padding="0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:TextTemplateControl MessageForeground="{Binding MessageForeground, RelativeSource={RelativeSource AncestorType={x:Type local:CardDescriptionControl}}}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </StackPanel>
    
</UserControl>
